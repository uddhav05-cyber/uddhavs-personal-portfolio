{
  "presets": [
    [
      "@babel/preset-env",
      {
        "useBuiltIns": "usage",
        "corejs": false,
        "targets": {
          "browsers": [
            "last 2 Chrome versions",
            "last 2 Firefox versions",
            "last 2 Safari versions",
            "last 2 Edge versions",
            "> 0.5%",
            "not dead",
            "not IE 11"
          ]
        },
        "modules": false,
        "bugfixes": true
      }
    ]
  ],
  "comments": false,
  "compact": true
}
