{
  "name": "portfolio-rebuild",
  "version": "1.0.0",
  "description": "Modern portfolio website for uddhavbhople.in with animations and Firebase integration",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "NODE_ENV=production vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "validate": "node scripts/pre-deploy.js",
    "predeploy": "npm run validate && npm run build:prod",
    "deploy": "firebase deploy --only hosting",
    "deploy:preview": "npm run build:prod && firebase hosting:channel:deploy preview",
    "deploy:full": "npm run validate && npm run build:prod && firebase deploy",
    "serve:firebase": "firebase serve"
  },
  "keywords": [
    "portfolio",
    "firebase",
    "vite"
  ],
  "author": "Uddhav Bhople",
  "license": "MIT",
  "dependencies": {
    "firebase": "^10.7.1",
    "intersection-observer": "^0.12.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "@vitejs/plugin-legacy": "^5.4.3",
    "@vitest/ui": "^1.1.0",
    "eslint": "^8.56.0",
    "jsdom": "^23.0.1",
    "terser": "^5.46.0",
    "vite": "^5.0.8",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^1.1.0"
  }
}
